# Tezsign appliance — shared ARM64 base defconfig.
# No SoC sub-architecture is enabled here; platform fragments add
# ARCH_BCM2835 (RPi) or ARCH_ROCKCHIP (Radxa) respectively.
#
# Fragment chain: defconfig → tezsign-common → platform-common → board → [dev]

CONFIG_EXPERT=y
CONFIG_SECCOMP=y
CONFIG_CRYPTO_HW=y

# ── Core system ──────────────────────────────────────────────────────────────
CONFIG_SYSVIPC=y
CONFIG_PM=y
CONFIG_NO_HZ_IDLE=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_PREEMPT=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
# CONFIG_CORE_DUMP_DEFAULT_ELF_HEADERS is not set
# CONFIG_COMPAT_BRK is not set
CONFIG_CMA=y
CONFIG_DMA_CMA=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_WQ_POWER_EFFICIENT_DEFAULT=y
CONFIG_JUMP_LABEL=y

# ── ARM64 platforms: all off ──────────────────────────────────────────────────
# Every ARCH_* defaults to y in Kconfig.platforms.  Disable all here;
# platform fragments enable the one they need (ARCH_BCM / ARCH_ROCKCHIP).
# CONFIG_ARCH_ACTIONS is not set
# CONFIG_ARCH_SUNXI is not set
# CONFIG_ARCH_ALPINE is not set
# CONFIG_ARCH_APPLE is not set
# CONFIG_ARCH_BCM is not set
# CONFIG_ARCH_BERLIN is not set
# CONFIG_ARCH_BRCMSTB is not set
# CONFIG_ARCH_EXYNOS is not set
# CONFIG_ARCH_K3 is not set
# CONFIG_ARCH_LAYERSCAPE is not set
# CONFIG_ARCH_LG1K is not set
# CONFIG_ARCH_HISI is not set
# CONFIG_ARCH_KEEMBAY is not set
# CONFIG_ARCH_MEDIATEK is not set
# CONFIG_ARCH_MESON is not set
# CONFIG_ARCH_MVEBU is not set
# CONFIG_ARCH_NXP is not set
# CONFIG_ARCH_MA35 is not set
# CONFIG_ARCH_NPCM is not set
# CONFIG_ARCH_QCOM is not set
# CONFIG_ARCH_REALTEK is not set
# CONFIG_ARCH_RENESAS is not set
# CONFIG_ARCH_ROCKCHIP is not set
# CONFIG_ARCH_S32 is not set
# CONFIG_ARCH_SEATTLE is not set
# CONFIG_ARCH_INTEL_SOCFPGA is not set
# CONFIG_ARCH_STM32 is not set
# CONFIG_ARCH_SYNQUACER is not set
# CONFIG_ARCH_TEGRA is not set
# CONFIG_ARCH_SPRD is not set
# CONFIG_ARCH_THUNDER is not set
# CONFIG_ARCH_THUNDER2 is not set
# CONFIG_ARCH_UNIPHIER is not set
# CONFIG_ARCH_VEXPRESS is not set
# CONFIG_ARCH_VISCONTI is not set
# CONFIG_ARCH_XGENE is not set
# CONFIG_ARCH_ZYNQMP is not set
# CONFIG_ARCH_AIROHA is not set

# ── Explicitly off: major features ───────────────────────────────────────────
# CONFIG_PCI is not set
# CONFIG_ACPI is not set
# CONFIG_VIRTUALIZATION is not set
# CONFIG_HIBERNATION is not set
# CONFIG_SUSPEND is not set
# CONFIG_BLK_DEV_INITRD is not set
# CONFIG_AUDIT is not set
# CONFIG_PROFILING is not set
# CONFIG_KEXEC is not set
# CONFIG_COMPAT is not set
# CONFIG_NUMA is not set
# CONFIG_IKCONFIG is not set
# CONFIG_XEN is not set
# CONFIG_KSM is not set
# CONFIG_TRANSPARENT_HUGEPAGE is not set
# CONFIG_BSD_PROCESS_ACCT is not set
# CONFIG_TASKSTATS is not set
# CONFIG_POSIX_MQUEUE is not set
# CONFIG_IRQ_TIME_ACCOUNTING is not set
# CONFIG_SCHED_SMT is not set
# CONFIG_SCHED_AUTOGROUP is not set
# CONFIG_USER_NS is not set
# CONFIG_MEMORY_HOTPLUG is not set
# CONFIG_MEMORY_FAILURE is not set
# CONFIG_HUGETLBFS is not set
# CONFIG_BPF_SYSCALL is not set
# CONFIG_IO_URING is not set
# CONFIG_SWAP is not set
# CONFIG_COREDUMP is not set
# CONFIG_PERF_EVENTS is not set
# CONFIG_AIO is not set
# CONFIG_USELIB is not set
# CONFIG_RELAY is not set
# CONFIG_KPROBES is not set
# CONFIG_CHECKPOINT_RESTORE is not set
# CONFIG_USERFAULTFD is not set
# CONFIG_SLUB_DEBUG is not set
# CONFIG_DNOTIFY is not set
# CONFIG_PROC_KCORE is not set

# ── Cgroups (systemd essentials only) ────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_PIDS=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_DEVICE=y
# CONFIG_BLK_CGROUP is not set
# CONFIG_CGROUP_FREEZER is not set
# CONFIG_CGROUP_HUGETLB is not set
# CONFIG_CGROUP_CPUACCT is not set
# CONFIG_CGROUP_PERF is not set

# ── CPU frequency ────────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPUFREQ_DT=y
CONFIG_ENERGY_MODEL=y
# CONFIG_CPU_FREQ_STAT is not set
# CONFIG_CPU_FREQ_GOV_POWERSAVE is not set
# CONFIG_CPU_FREQ_GOV_USERSPACE is not set
# CONFIG_ARM_SCPI_CPUFREQ is not set
# CONFIG_ARM_SCMI_CPUFREQ is not set

# ── Networking ───────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_UNIX=y
CONFIG_PACKET=y
CONFIG_INET=y
CONFIG_NETDEVICES=y
# CONFIG_IP_PNP is not set
# CONFIG_IP_MULTICAST is not set
# CONFIG_IPV6 is not set
# CONFIG_NETFILTER is not set
# CONFIG_BRIDGE is not set
# CONFIG_VLAN_8021Q is not set
# CONFIG_NET_SCHED is not set
# CONFIG_NET_DSA is not set
# CONFIG_NET_9P is not set
# CONFIG_HSR is not set
# CONFIG_WWAN is not set
# CONFIG_BT is not set
# CONFIG_CFG80211 is not set
# CONFIG_RFKILL is not set
# CONFIG_CAN is not set
# CONFIG_NFC is not set
# CONFIG_TUN is not set
# CONFIG_MACVLAN is not set
# CONFIG_VETH is not set
# CONFIG_ETHERNET is not set
# CONFIG_WLAN is not set
# CONFIG_MAC80211 is not set
# CONFIG_WIRELESS is not set
# CONFIG_HAMRADIO is not set
# CONFIG_QRTR is not set

# ── Device infrastructure ────────────────────────────────────────────────────
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_FW_LOADER_USER_HELPER=y
CONFIG_SRAM=y
# CONFIG_ARM_SCMI_PROTOCOL is not set
# CONFIG_ARM_SCPI_PROTOCOL is not set
# CONFIG_EFI_CAPSULE_LOADER is not set
# CONFIG_VEXPRESS_CONFIG is not set
# CONFIG_CONNECTOR is not set
# CONFIG_GNSS is not set
# CONFIG_MHI_BUS is not set
# CONFIG_RPMSG is not set
# CONFIG_RPMSG_VIRTIO is not set

# ── I2C ──────────────────────────────────────────────────────────────────────
CONFIG_I2C=y
# CONFIG_I2C_CHARDEV is not set
# CONFIG_I2C_MUX is not set
# CONFIG_I2C_DESIGNWARE_CORE is not set
# CONFIG_I2C_GPIO is not set
# CONFIG_I2C_CADENCE is not set
# CONFIG_I2C_CROS_EC_TUNNEL is not set

# ── Regulators ───────────────────────────────────────────────────────────────
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_GPIO=y
# CONFIG_REGULATOR_ARM_SCMI is not set
# CONFIG_REGULATOR_PWM is not set

# ── Serial ───────────────────────────────────────────────────────────────────
# CONFIG_SERIAL_8250 is not set
# CONFIG_SERIAL_8250_CONSOLE is not set
# CONFIG_SERIAL_8250_NR_UARTS is not set
# CONFIG_SERIAL_8250_EXTENDED is not set
# CONFIG_SERIAL_8250_SHARE_IRQ is not set
# CONFIG_SERIAL_OF_PLATFORM is not set
# CONFIG_LEGACY_PTYS is not set
# CONFIG_SERIAL_AMBA_PL011 is not set
# CONFIG_SERIAL_XILINX_PS_UART is not set
# CONFIG_SERIAL_FSL_LPUART is not set
# CONFIG_SERIAL_FSL_LINFLEXUART is not set
# CONFIG_SERIAL_DEV_BUS is not set
# CONFIG_IPMI_HANDLER is not set
# CONFIG_TCG_TPM is not set
# CONFIG_EEPROM_AT24 is not set

# ── GPIO / Pinctrl ──────────────────────────────────────────────────────────
CONFIG_GPIO_SYSCON=y
CONFIG_PINCTRL_SINGLE=y
# CONFIG_GPIO_DWAPB is not set
# CONFIG_GPIO_PL061 is not set
# CONFIG_GPIO_XGENE is not set
# CONFIG_GPIO_ALTERA is not set
# CONFIG_GPIO_AGGREGATOR is not set

# ── DMA ──────────────────────────────────────────────────────────────────────
CONFIG_DMADEVICES=y
# CONFIG_FSL_EDMA is not set
# CONFIG_MV_XOR_V2 is not set
# CONFIG_DW_EDMA is not set

# ── PWM ──────────────────────────────────────────────────────────────────────
CONFIG_PWM=y

# ── SPI: not used ────────────────────────────────────────────────────────────
# CONFIG_SPI is not set
# CONFIG_SPMI is not set

# ── USB gadget path ──────────────────────────────────────────────────────────
# Platform controller (DWC2 or DWC3) enabled by platform fragment.
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_F_FS=y
CONFIG_USB_F_ECM=y
CONFIG_USB_F_FS=y
# CONFIG_USB_XHCI_HCD is not set
# CONFIG_USB_EHCI_HCD is not set
# CONFIG_USB_OHCI_HCD is not set
# CONFIG_USB_STORAGE is not set
# CONFIG_USB_OTG is not set
# CONFIG_USB_MUSB_HDRC is not set
# CONFIG_USB_CDNS_SUPPORT is not set
# CONFIG_TYPEC is not set
# CONFIG_USB_ISP1760 is not set
# CONFIG_USB_HSIC_USB3503 is not set
# CONFIG_USB_ONBOARD_DEV is not set
# CONFIG_USB_CONN_GPIO is not set
# CONFIG_NOP_USB_XCEIV is not set
# CONFIG_USB_ULPI is not set
# CONFIG_USB_ACM is not set
# CONFIG_USB_NET_DRIVERS is not set
# CONFIG_USB_SERIAL is not set
# CONFIG_USB_CONFIGFS_SERIAL is not set
# CONFIG_USB_CONFIGFS_ACM is not set
# CONFIG_USB_CONFIGFS_OBEX is not set
# CONFIG_USB_CONFIGFS_NCM is not set
# CONFIG_USB_CONFIGFS_ECM_SUBSET is not set
# CONFIG_USB_CONFIGFS_RNDIS is not set
# CONFIG_USB_CONFIGFS_EEM is not set
# CONFIG_USB_CONFIGFS_MASS_STORAGE is not set
# CONFIG_USB_F_ACM is not set
# CONFIG_USB_F_SERIAL is not set
# CONFIG_USB_F_OBEX is not set
# CONFIG_USB_F_NCM is not set
# CONFIG_USB_F_EEM is not set
# CONFIG_USB_F_SUBSET is not set
# CONFIG_USB_F_RNDIS is not set
# CONFIG_USB_F_MASS_STORAGE is not set
# CONFIG_USB_CHIPIDEA is not set
# CONFIG_USB_USBNET is not set
# CONFIG_USB_NET_CDCETHER is not set
# CONFIG_USB_UAS is not set

# ── MMC ──────────────────────────────────────────────────────────────────────
# Platform host driver enabled by platform/board fragment.
CONFIG_MMC=y
# CONFIG_MMC_ARMMMCI is not set
# CONFIG_MMC_STM32_SDMMC is not set
# CONFIG_MMC_SDHCI_ACPI is not set
# CONFIG_MMC_SDHCI_OF_DWCMSHC is not set
# CONFIG_MMC_SDHCI_CADENCE is not set
# CONFIG_MMC_SDHCI_F_SDH30 is not set
# CONFIG_MMC_SPI is not set
# CONFIG_MMC_DW_EXYNOS is not set
# CONFIG_MMC_DW_HI3798CV200 is not set
# CONFIG_MMC_DW_K3 is not set
# CONFIG_MMC_MTK is not set
# CONFIG_MMC_SDHCI_XENON is not set

# ── LED subsystem ────────────────────────────────────────────────────────────
CONFIG_NEW_LEDS=y
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_LEDS_TRIGGER_DEFAULT_ON=y
CONFIG_LEDS_TRIGGER_PANIC=y
# CONFIG_LEDS_PWM is not set
# CONFIG_LEDS_SYSCON is not set

# ── Thermal ──────────────────────────────────────────────────────────────────
# Platform thermal driver enabled by board fragment.
CONFIG_CPU_THERMAL=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
# CONFIG_DEVFREQ_THERMAL is not set
# CONFIG_THERMAL_EMULATION is not set

# ── HWMON: off (thermal framework still works) ──────────────────────────────
# CONFIG_HWMON is not set

# ── Crypto / HW RNG ─────────────────────────────────────────────────────────
# Platform HW RNG enabled by platform fragment.
CONFIG_HW_RANDOM=y
CONFIG_CRYPTO_GHASH_ARM64_CE=y
CONFIG_CRYPTO_SHA1_ARM64_CE=y
CONFIG_CRYPTO_SHA2_ARM64_CE=y
CONFIG_CRYPTO_AES_ARM64_CE_CCM=y
# CONFIG_CRYPTO_USER is not set
# CONFIG_CRYPTO_TEST is not set
# CONFIG_CRYPTO_DES is not set
# CONFIG_CRYPTO_ANSI_CPRNG is not set
# CONFIG_CRYPTO_USER_API_RNG is not set

# ── Filesystems ──────────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_VFAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
# CONFIG_EXT4_FS_SECURITY is not set
# CONFIG_BTRFS_FS is not set
# CONFIG_FUSE_FS is not set
# CONFIG_CUSE is not set
# CONFIG_OVERLAY_FS is not set
# CONFIG_SQUASHFS is not set
# CONFIG_NFS_FS is not set
# CONFIG_ROOT_NFS is not set
# CONFIG_9P_FS is not set
# CONFIG_UBIFS_FS is not set
# CONFIG_EROFS_FS is not set
# CONFIG_JFFS2_FS is not set
# CONFIG_CRAMFS is not set
# CONFIG_ROMFS_FS is not set
# CONFIG_ECRYPT_FS is not set
# CONFIG_HFS_FS is not set
# CONFIG_HFSPLUS_FS is not set
# CONFIG_UFS_FS is not set
# CONFIG_F2FS_FS is not set
# CONFIG_NTFS3_FS is not set
# CONFIG_EXFAT_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_GFS2_FS is not set
# CONFIG_OCFS2_FS is not set
# CONFIG_NILFS2_FS is not set
# CONFIG_NETWORK_FILESYSTEMS is not set
# CONFIG_FANOTIFY is not set
# CONFIG_QUOTA is not set
CONFIG_AUTOFS_FS=y
# CONFIG_EFIVAR_FS is not set
# CONFIG_PSTORE_RAM is not set
# CONFIG_SECURITY is not set

# ── Power ────────────────────────────────────────────────────────────────────
CONFIG_POWER_RESET_SYSCON=y
CONFIG_POWER_RESET_SYSCON_POWEROFF=y
CONFIG_SYSCON_REBOOT_MODE=y
# CONFIG_POWER_RESET_XGENE is not set
# CONFIG_POWER_SEQUENCING is not set
# CONFIG_POWER_SUPPLY is not set
# CONFIG_BATTERY_SBS is not set
# CONFIG_BATTERY_BQ27XXX is not set

# ── Headless production defaults ─────────────────────────────────────────────
# Dev fragments override these with =y for HDMI console rescue.
# CONFIG_DRM is not set
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_FB is not set
# CONFIG_FRAMEBUFFER_CONSOLE is not set
# CONFIG_VT is not set
# CONFIG_INPUT is not set
