# ── Networking ──────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_UNIX=y

# ── Block layer / IO scheduling ────────────────────────────────────────────
CONFIG_MQ_IOSCHED_DEADLINE=y
CONFIG_IOSCHED_BFQ=y
CONFIG_SCSI_MQ_DEFAULT=y
