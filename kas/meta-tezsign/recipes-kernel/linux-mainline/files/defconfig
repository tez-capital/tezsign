# ── Regulators ──────────────────────────────────────────────────────────────
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_GPIO=y

# ── GPIO / Pinctrl ─────────────────────────────────────────────────────────
CONFIG_PINCTRL_SINGLE=y

# ── DMA ─────────────────────────────────────────────────────────────────────
CONFIG_DMADEVICES=y
CONFIG_PL330_DMA=y

# ── PWM ─────────────────────────────────────────────────────────────────────
CONFIG_PWM=y

# ── MMC / SD ────────────────────────────────────────────────────────────────
