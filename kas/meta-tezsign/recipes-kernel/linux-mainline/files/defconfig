# ══════════════════════════════════════════════════════════════════════════════
# tezsign kernel defconfig — ARM64
# ══════════════════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────────────────
CONFIG_EXPERT=y
CONFIG_MODULES=n
CONFIG_PRINTK_TIME=y
# CONFIG_LOCALVERSION_AUTO is not set

# ── RT / preemption / timers ────────────────────────────────────────────────
CONFIG_PREEMPT_RT=y
CONFIG_HZ_1000=y
CONFIG_HZ_250=n
CONFIG_NO_HZ_FULL=y
CONFIG_NO_HZ_IDLE=n
CONFIG_HIGH_RES_TIMERS=y
CONFIG_IRQ_TIME_ACCOUNTING=y
CONFIG_IRQ_FORCED_THREADING=y
# CONFIG_ARM_ARCH_TIMER_EVTSTREAM is not set

# ── Scheduler ───────────────────────────────────────────────────────────────
CONFIG_SCHED_MC=y
CONFIG_SCHED_THERMAL_PRESSURE=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
# CONFIG_SCHED_SMT is not set
# CONFIG_SCHED_CLUSTER is not set

# ── RCU ─────────────────────────────────────────────────────────────────────
CONFIG_RCU_NOCB_CPU=y
CONFIG_RCU_NOCB_CPU_CB_BOOST=y

# ── CPU frequency ───────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_TIMES=y
CONFIG_ENERGY_MODEL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=n
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=n
CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND=n
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=n
CONFIG_CPUFREQ_DT=y

# ── CPU idle ────────────────────────────────────────────────────────────────
CONFIG_CPU_IDLE=y
CONFIG_ARM_PSCI_CPUIDLE=y
CONFIG_CPU_IDLE_GOV_MENU=y

# ── Cgroups (systemd essentials) ────────────────────────────────────────────
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_PIDS=y
CONFIG_CPUSETS=y
CONFIG_CGROUP_DEVICE=y

# ── Memory management ──────────────────────────────────────────────────────
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_CMA=y
CONFIG_CMA_AREAS=7
CONFIG_CMA_SIZE_MBYTES=5
CONFIG_DMA_CMA=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y
CONFIG_COMPACTION=y
CONFIG_MIGRATION=y
CONFIG_SLUB_CPU_PARTIAL=y
# CONFIG_SWAP is not set
# CONFIG_SLAB_MERGE_DEFAULT is not set
# CONFIG_COMPAT_BRK is not set

# ── Binary formats / syscall interface ──────────────────────────────────────
CONFIG_SYSVIPC=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_FHANDLE=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EPOLL=y
CONFIG_INOTIFY_USER=y
CONFIG_SECCOMP=y
# CONFIG_DNOTIFY is not set
# CONFIG_BINFMT_MISC is not set
# CONFIG_AIO is not set

# ── Namespaces (disabled) ──────────────────────────────────────────────────
# CONFIG_CPU_ISOLATION is not set
# CONFIG_UTS_NS is not set
# CONFIG_TIME_NS is not set
# CONFIG_PID_NS is not set

# ── ARM64 architecture ─────────────────────────────────────────────────────
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_PAN=y
CONFIG_ARM64_USE_LSE_ATOMICS=y
CONFIG_ARM64_CNP=y
CONFIG_ARM64_HW_AFDBM=y
CONFIG_ARM64_TLB_RANGE=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_GIC_V3_ITS=y
CONFIG_RANDOMIZE_BASE=y
CONFIG_KERNEL_MODE_NEON=y
# CONFIG_ARM64_SVE is not set
# CONFIG_ARM64_RAS_EXTN is not set
# CONFIG_ARM64_AMU_EXTN is not set
# CONFIG_ARM64_POE is not set
# CONFIG_ARM64_GCS is not set
# CONFIG_ARM64_TAGGED_ADDR_ABI is not set
# CONFIG_EFI is not set

# ── ARM64 self-protection ──────────────────────────────────────────────────
# CONFIG_UNMAP_KERNEL_AT_EL0 is not set
CONFIG_ARM64_SW_TTBR0_PAN=y
# CONFIG_SHADOW_CALL_STACK is not set
CONFIG_UNWIND_PATCH_PAC_INTO_SCS=y
# ONFIG_MITIGATE_SPECTRE_BRANCH_HISTORY is not set
# CONFIG_ARM64_PTR_AUTH is not set
# CONFIG_ARM64_PTR_AUTH_KERNEL is not set
CONFIG_ARM64_BTI=y
CONFIG_ARM64_BTI_KERNEL=y
# CONFIG_ARM64_MTE is not set
CONFIG_ARM64_E0PD=y
CONFIG_ARM64_EPAN=y

# ── Memory allocator hardening ──────────────────────────────────────────────
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLAB_FREELIST_RANDOM=y
# CONFIG_INIT_STACK_ALL_ZERO is not set
# CONFIG_RANDOM_KMALLOC_CACHES is not set
# CONFIG_SHUFFLE_PAGE_ALLOCATOR is not set
# CONFIG_INIT_ON_ALLOC_DEFAULT_ON is not set
# CONFIG_INIT_ON_FREE_DEFAULT_ON is not set
# CONFIG_RANDOMIZE_KSTACK_OFFSET_DEFAULT is not set

# ── Kernel code / data integrity ────────────────────────────────────────────
CONFIG_BUG=y
CONFIG_FORTIFY_SOURCE=y
# CONFIG_HARDENED_USERCOPY is not set
CONFIG_LIST_HARDENED=y
CONFIG_STRICT_KERNEL_RWX=y
# CONFIG_BUG_ON_DATA_CORRUPTION is not set
# CONFIG_ZERO_CALL_USED_REGS is not set
# CONFIG_DEBUG_WX is not set
# CONFIG_KASAN_HW_TAGS is not set

# ── Page table hardening ────────────────────────────────────────────────────
# CONFIG_PAGE_TABLE_CHECK is not set

# ── UBSAN ───────────────────────────────────────────────────────────────────
# CONFIG_UBSAN is not set

# ── KFENCE ──────────────────────────────────────────────────────────────────
# CONFIG_KFENCE is not set

# ── Attack surface reduction ───────────────────────────────────────────────
CONFIG_SECURITY_DMESG_RESTRICT=y
CONFIG_STATIC_USERMODEHELPER=y
# CONFIG_PROC_KCORE is not set
# CONFIG_USERFAULTFD is not set
# CONFIG_IO_URING is not set
# CONFIG_KEXEC is not set
# CONFIG_KPROBES is not set
# CONFIG_BPF_SYSCALL is not set
