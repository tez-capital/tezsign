From 9913e91273751db7b0e24a821c07f3e1fdc2821f Mon Sep 17 00:00:00 2001
From: tezsign <tezsign@tez.capital>
Date: Wed, 22 Apr 2026 16:46:01 +0200
Subject: [PATCH] arm64: dts: rockchip: radxa zero 3w: USB peripheral only

---
 arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3.dtsi | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3.dtsi b/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3.dtsi
index 1ee5d96a46a1..b50097cf3828 100644
--- a/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3.dtsi
+++ b/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3.dtsi
@@ -494,10 +494,11 @@ &uart2 {
 
 &usb_host0_xhci {
 	status = "okay";
+	dr_mode = "peripheral";
 };
 
 &usb_host1_xhci {
-	status = "okay";
+	status = "disabled";
 };
 
 &usb2phy0 {
@@ -505,11 +506,12 @@ &usb2phy0 {
 };
 
 &usb2phy0_host {
-	status = "okay";
+	status = "disabled";
 };
 
 &usb2phy0_otg {
 	status = "okay";
+	dr_mode = "peripheral";
 };
 
 &vop {
-- 
2.53.0

