From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: tezsign <tezsign@tez.capital>
Date: Wed, 16 Apr 2026 00:00:00 +0000
Subject: [PATCH] arm64: dts: rockchip: radxa zero 3w: USB peripheral mode,
 disable WiFi and BT

Switch the USB-C DWC3 OTG port to peripheral-only mode (for USB gadget)
and disable the SDIO WiFi (sdmmc1) and UART Bluetooth (uart1) interfaces
that are unused on the tezsign appliance.

Signed-off-by: tezsign <tezsign@tez.capital>
---
 .../boot/dts/rockchip/rk3566-radxa-zero-3w.dts    | 16 ++++++++++++++++
 1 file changed, 16 insertions(+)

diff --git a/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3w.dts b/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3w.dts
index 111111111111..222222222222 100644
--- a/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3w.dts
+++ b/arch/arm64/boot/dts/rockchip/rk3566-radxa-zero-3w.dts
@@ -87,6 +87,22 @@
 &uart1 {
 	pinctrl-names = "default";
 	pinctrl-0 = <&uart1m0_xfer &uart1m0_ctsn &uart1m0_rtsn>;
 	uart-has-rtscts;
 	status = "okay";
 };
+
+/* TezSign: USB-C as peripheral only (gadget mode) */
+&usb_host0_xhci {
+	dr_mode = "peripheral";
+};
+
+/* TezSign: WiFi and Bluetooth not used */
+&sdio_pwrseq {
+	status = "disabled";
+};
+&sdmmc1 {
+	status = "disabled";
+};
+&uart1 {
+	status = "disabled";
+};
-- 
