# Rockchip SD-card image layout for TezSign.
# Bootloader binaries (idbloader, u-boot) are written to raw sectors
# via post-processing (dd), NOT as GPT partitions. This matches the
# Armbian approach for maximum Rockchip BootROM compatibility.
# See: https://opensource.rock-chips.com/wiki_Partitions
#
# Raw layout (no GPT entries):
#   sector 64    -> idbloader.img  (SPL)
#   sector 16384 -> u-boot.itb     (U-Boot proper)
#
# GPT partitions start at sector 32768 (16 MiB):

part / --offset 32768s --label rootfsA --active --fstype=ext4 --part-name rootfsA --source rootfs --part-type ${ROOT_DPS} --size 512M
part /app --source rootfs --rootfs-dir=${DEPLOY_DIR_IMAGE}/appfs --ondisk mmcblk0 --fstype=ext4 --label app --part-name app --align 4096 --fixed-size 64M --fsoptions="ro,exec,noatime,nofail"
part /data --ondisk mmcblk0 --fstype=ext4 --label data --part-name data --align 4096 --fixed-size 128M --mkfs-extraopts="-J size=8 -m 0 -I 1024 -O has_journal,inline_data,fast_commit" --fsoptions="rw,noatime,nofail,data=journal"

bootloader --ptable gpt
