[Unit]
Description=Enable tezsign FFS (create gadget, link functions, mount /dev/ffs/tezsign)
# Ensure the SD card partitions are mounted BEFORE we run
RequiresMountsFor=/app /data
After=local-fs.target generate-serial.service

[Service]
Type=oneshot
ExecStart=/usr/bin/setup-gadget
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
