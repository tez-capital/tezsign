[Unit]
Description=Attach gadget to UDC (bind) and fix endpoint perms
After=setup-gadget-dev.service ffs_registrar.service
Requires=ffs_registrar.service
StartLimitIntervalSec=0

[Service]
Type=oneshot
ExecStartPre=/usr/bin/udevadm settle --timeout=5
ExecStartPre=/usr/bin/sleep 5
ExecStart=/usr/bin/attach-gadget
RemainAfterExit=yes
Restart=on-failure
RestartSec=1s

StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
